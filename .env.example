# Copie para .env e preencha

# TMDB - crie uma chave em https://www.themoviedb.org/settings/api (use a "API Read Access Token" v4 ou a chave v3)
TMDB_API_KEY=

# Jackett
JACKETT_URL=http://localhost:9117
JACKETT_API_KEY=

# qBittorrent (Web UI precisa estar habilitada em Ferramentas > Opcoes > Web UI)
QBIT_URL=http://localhost:8080
QBIT_USER=admin
QBIT_PASS=

# Destino inicial dos torrents (opcional). Na primeira execucao vira o destino de
# torrents "Padrao (.env)" cadastrado no banco; depois voce gerencia pela aba
# "Configuracoes" da interface. QBIT_SAVE_PATH = onde o qBittorrent salva (visao
# DELE; vazio = pasta padrao). QBIT_PATH_MAP = como esse caminho e visto por este
# servico (origem=>destino; o primeiro par vira o par save->local do target).
QBIT_SAVE_PATH=
QBIT_PATH_MAP=

# Watchdog: minutos sem progresso antes de trocar o torrent pelo proximo candidato. 0 desativa.
STALL_TIMEOUT_MINUTES=15

# O que fazer com os torrents apos o merge: keep (padrao) | remove | remove_data
QBIT_CLEANUP=keep

# Pasta de destino inicial do arquivo final. Na primeira execucao vira o destino
# "Padrao" cadastrado no banco; depois voce gerencia os destinos pela aba "Configuracoes"
# da interface (adiciona/edita/remove pastas e escolhe qual usar em cada download).
OUTPUT_DIR=C:\Users\user\Videos\merged
